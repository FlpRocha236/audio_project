{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "watchPatterns": ["requirements.txt", "separator/**"],
    "nixpacksConfigPath": "nixpacks.toml"
  },
  "deploy": {
    "startCommand": "gunicorn audio_project.wsgi:application --bind 0.0.0.0:$PORT"
  }
}
